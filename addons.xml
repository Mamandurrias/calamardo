<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.miseries" name="Mis Series" version="1.0.5" provider-name="VPS">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary>Mis series con temporadas</summary>
    <description>Series desde VPS con carpetas de temporadas</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
<addon id="repository.calamardo" name="Calamardo Repository" version="1.0.1" provider-name="VPS">
  <requires>
    <import addon="xbmc.addon" version="18.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="Calamardo Repository">
    <dir minversion="18.0.0">
      <info compressed="false">https://mamandurrias.github.io/calamardo/addons.xml</info>
      <checksum>https://mamandurrias.github.io/calamardo/addons.xml.md5</checksum>
      <datadir zip="true">https://mamandurrias.github.io/calamardo/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary>Repositorio Calamardo</summary>
    <platform>all</platform>
  </extension>
</addon>
</addons>